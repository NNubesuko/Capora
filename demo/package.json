{
  "name": "capora-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm -r --filter @capora/core --filter @capora/runtime --filter @capora/sdk --filter @capora/ui-contracts --filter @capora/adapter-web build",
    "dev": "concurrently --names api,web --prefix-colors cyan,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch api/src/server.ts",
    "dev:web": "vite web"
  },
  "dependencies": {
    "@capora/core":         "workspace:*",
    "@capora/runtime":      "workspace:*",
    "@capora/sdk":          "workspace:*",
    "@capora/adapter-web":  "workspace:*",
    "@capora/ui-contracts": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node":  "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx":          "^4.19.2",
    "typescript":   "^5.7.3",
    "vite":         "^5.4.21"
  }
}
