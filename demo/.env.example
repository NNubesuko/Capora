# Server
DEMO_API_PORT=3031
DEMO_API_HOST=127.0.0.1

# Planner (default: rule-based, no LLM required)
# To enable the LLM planner, set CAPORA_PLANNER=llm and configure one provider below.
# CAPORA_PLANNER=llm

# --- OpenAI-compatible (OpenAI, Ollama, Groq, OpenRouter, Azure, etc.) ---
# CAPORA_LLM_PROVIDER=openai-compatible
# CAPORA_LLM_BASE_URL=https://api.openai.com/v1
# CAPORA_LLM_API_KEY=your-api-key-here
# CAPORA_LLM_MODEL=gpt-4o-mini

# --- OpenAI (Responses API) ---
# CAPORA_LLM_PROVIDER=openai
# OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Amazon Bedrock ---
# CAPORA_LLM_PROVIDER=bedrock
# BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
# AWS_REGION=us-east-1
# (credentials via AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY or IAM role)
